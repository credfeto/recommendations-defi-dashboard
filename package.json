{
  "name": "recommendations-defi-dashboard",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/client",
    "packages/server"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "start": "npm --workspace=@defi-dashboard/client start",
    "server": "npm --workspace=@defi-dashboard/server start",
    "dev": "concurrently \"npm run server\" \"npm run start\"",
    "build": "npm --workspace=@defi-dashboard/client run build",
    "test": "npm --workspace=@defi-dashboard/server test",
    "test:coverage": "npm --workspace=@defi-dashboard/server run test:coverage",
    "test:watch": "npm --workspace=@defi-dashboard/server run test:watch",
    "prepare": "husky"
  }
}
